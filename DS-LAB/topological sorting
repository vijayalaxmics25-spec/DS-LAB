#include <stdio.h>

int main() {
    int n, i, j;
    printf("Enter number of vertices: ");
    scanf("%d", &n);

    int adj[n][n], indegree[n];

    printf("Enter adjacency matrix:\n");
    for(i = 0; i < n; i++) {
        for(j = 0; j < n; j++) {
            scanf("%d", &adj[i][j]);
        }
    }

    // Calculate indegree
    for(i = 0; i < n; i++)
        indegree[i] = 0;

    for(i = 0; i < n; i++) {
        for(j = 0; j < n; j++) {
            if(adj[i][j] == 1)
                indegree[j]++;
        }
    }

    printf("Topological Order: ");

    int count = 0;

    while(count < n) {
        int found = 0;

        for(i = 0; i < n; i++) {
            if(indegree[i] == 0) {
                printf("%d ", i);

                indegree[i] = -1; // Mark as removed

                for(j = 0; j < n; j++) {
                    if(adj[i][j] == 1)
                        indegree[j]--;
                }

                found = 1;
                count++;
            }
        }

        if(!found) {
            printf("\nGraph contains a cycle!\n");
            return 0;
        }
    }

    return 0;
}
