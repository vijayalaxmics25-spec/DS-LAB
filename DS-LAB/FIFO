#include <stdio.h>

int main() {
    int n, f, i, j, k = 0, fault = 0, found;

    printf("Enter number of pages: ");
    scanf("%d", &n);

    int page[n];
    printf("Enter page reference string: ");
    for(i = 0; i < n; i++)
        scanf("%d", &page[i]);

    printf("Enter number of frames: ");
    scanf("%d", &f);

    int frame[f];

    for(i = 0; i < f; i++)
        frame[i] = -1;

    for(i = 0; i < n; i++) {
        found = 0;

        for(j = 0; j < f; j++)
            if(frame[j] == page[i])
                found = 1;

        if(!found) {
            frame[k] = page[i];
            k = (k + 1) % f;
            fault++;
        }
    }

    printf("Total Page Faults = %d\n", fault);
    return 0;
}
