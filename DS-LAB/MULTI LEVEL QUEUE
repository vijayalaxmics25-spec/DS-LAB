#include <stdio.h>

int main() {
    int n, i;
    float avg_tat = 0, avg_wt = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    int at[n], bt[n], type[n];
    int ct[n], tat[n], wt[n];

    for(i = 0; i < n; i++) {
        printf("\nProcess P%d\n", i + 1);

        printf("Enter AT and BT: ");
        scanf("%d%d", &at[i], &bt[i]);

        printf("Enter Type (1-System, 2-User): ");
        scanf("%d", &type[i]);
    }

    int time = 0;

    // System Processes First
    for(i = 0; i < n; i++) {
        if(type[i] == 1) {
            if(time < at[i])
                time = at[i];

            time += bt[i];
            ct[i] = time;
        }
    }

    // User Processes Next
    for(i = 0; i < n; i++) {
        if(type[i] == 2) {
            if(time < at[i])
                time = at[i];

            time += bt[i];
            ct[i] = time;
        }
    }

    for(i = 0; i < n; i++) {
        tat[i] = ct[i] - at[i];
        wt[i] = tat[i] - bt[i];

        avg_tat += tat[i];
        avg_wt += wt[i];
    }

    avg_tat /= n;
    avg_wt /= n;

    printf("\nP\tAT\tBT\tType\tCT\tTAT\tWT\n");

    for(i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\t%d\n",
               i + 1, at[i], bt[i], type[i],
               ct[i], tat[i], wt[i]);
    }

    printf("\nAverage Turnaround Time = %.2f", avg_tat);
    printf("\nAverage Waiting Time = %.2f\n", avg_wt);

    return 0;
}
