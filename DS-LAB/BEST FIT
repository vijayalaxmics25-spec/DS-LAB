#include <stdio.h>

int main() {
    int nb, np, i, j;

    printf("Enter number of blocks: ");
    scanf("%d", &nb);

    int block[nb];

    printf("Enter block sizes:\n");
    for(i = 0; i < nb; i++)
        scanf("%d", &block[i]);

    printf("Enter number of processes: ");
    scanf("%d", &np);

    int process[np], alloc[np];

    printf("Enter process sizes:\n");
    for(i = 0; i < np; i++)
        scanf("%d", &process[i]);

    for(i = 0; i < np; i++)
        alloc[i] = -1;

    for(i = 0; i < np; i++) {
        int best = -1;

        for(j = 0; j < nb; j++) {
            if(block[j] >= process[i]) {
                if(best == -1 || block[j] < block[best])
                    best = j;
            }
        }

        if(best != -1) {
            alloc[i] = best;
            block[best] -= process[i];
        }
    }

    printf("\nProcess\tBlock\n");
    for(i = 0; i < np; i++)
        printf("P%d\t%d\n", i + 1, alloc[i] + 1);

    return 0;
}
