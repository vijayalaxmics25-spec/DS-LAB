#include <stdio.h>

int main() {
    int n, i, j;

    printf("Enter number of tasks: ");
    scanf("%d", &n);

    int bt[n], period[n], task[n];

    for(i = 0; i < n; i++) {
        task[i] = i + 1;   // Store original task numbers

        printf("Enter Execution time && period for task %d: ", i + 1);
        scanf("%d%d", &bt[i], &period[i]);
    }

    // Sort tasks based on period (Rate Monotonic Scheduling)
    for(i = 0; i < n - 1; i++) {
        for(j = i + 1; j < n; j++) {
            if(period[i] > period[j]) {
                int temp;

                temp = period[i];
                period[i] = period[j];
                period[j] = temp;

                temp = bt[i];
                bt[i] = bt[j];
                bt[j] = temp;

                temp = task[i];
                task[i] = task[j];
                task[j] = temp;
            }
        }
    }

    printf("\nTask\tExecution Time\tPeriod\tPriority\n");

    for(i = 0; i < n; i++) {
        printf("T%d\t%d\t\t%d\t%d\n",
               task[i], bt[i], period[i], i + 1);
    }

    printf("\nExecution Order (highest priority first):\n");

    for(i = 0; i < n; i++) {
        printf("T%d", task[i]);
        if(i < n - 1)
            printf(" -> ");
    }

    printf("\n");

    return 0;
}
